# LLM Configuration
LLM_BASE_URL=https://llm-dev-01.planet-ai.de/v1/
LLM_API_KEY=pai
LLM_MODEL_NAME=pai-chat

# Security
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32

# Authentication
# Set to "true" to disable login screen and use anonymous sessions
# Each browser will get a unique session with "Ulrike Schlüter" as the user
DISABLE_LOGIN=false

# Database (using SQLite by default)
# DATABASE_URL=sqlite+aiosqlite:///./chat.db

# RAG Service (optional - if not set, RAG features will be skipped)
RAG_SERVICE_URL=http://gpu-server-ip:8001
