# RAG Service Configuration

# Embedding model (sentence-transformers model name)
MODEL_NAME=sentence-transformers/all-mpnet-base-v2

# GPU device to use (cuda:0, cuda:1, etc.)
CUDA_DEVICE=cuda:0

# Hugging Face cache directory (change if you have permission issues)
# Will use ./data/model_cache if not set
HF_HOME=./data/model_cache

# Qdrant vector database path
QDRANT_PATH=./data/qdrant

# Upload directory for storing original files
UPLOAD_DIR=./data/uploads

# Server configuration
HOST=0.0.0.0
PORT=8001

# CLI configuration (for cli.py)
RAG_SERVICE_URL=http://localhost:8001
